
# This file tells Git which files and folders to never track or commit. 
# This protects secrets, ignores generated files, and keeps the repository clean. 
# Anyone cloning the repo won't get your local machine's clutter.


# ----- Secrets & environment variables -----

# CRITICAL: .env contains DATABASE_URL and other secrets.
# Never commit this - it would expose credentials publicly on GitHub.
.env
.env.local
.env.*.local

# ----- Ruby & Bundler ----- 

# Gemfile.lock pins exact gem versions. Choice to commit it will depend on the project type:
#   -- Applications (like this one): DO commit Gemfile.lock so all developers and CI use identical gem versions.
#   -- Gems/libraries: DON'T commit it (other projects have their own lockfile).

# We leave Gemfile.lock tracked (not listed here) - that is the right choice for an application.

# Bundler stores installed gems here when using local paths
/.bundle/

# ----- Coverage reports -----
# Generated by SimpleCov when running: COVERAGE=true bundle exec rspec
# Large HTML report - regenerate locally, don't commit.
/coverage/

# ----- Logs -----
*.log
/log/

# ----- macOS -----
# Hidden file macOS creates in every folder — useless to other developers.
.DS_Store

# ----- Editor & IDE files -----
# VS Code workspace settings (keep .vscode/extensions.json if you want to recommend extensions to teammates, but ignore personal settings).
.vscode/settings.json
.vscode/launch.json

# RubyMine / JetBrains
.idea/

# ----- Temp / OS files -----
*.swp
*.swo
*~